pipeline {
    agent any

    stages {

        stage('Clone Code') {
            steps {
                echo "Cloning repository..."
                git 'https://github.com/dinesh-sirmal/Docker-file.git'
            }
        }

        stage('Build & Run Containers') {
            steps {
                echo "Running Docker Compose..."
                sh 'docker compose down || true'
                sh 'docker compose up -d --build'
            }
        }

        stage('Verify') {
            steps {
                sh 'docker ps'
            }
        }
    }
}
