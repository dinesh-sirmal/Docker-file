pipeline {
    agent any

    environment {
        IMAGE_NAME = "lab2_app_image"
        CONTAINER_NAME = "lab2_app_container"
    }

    stages {
        stage('Checkout Code') {
            steps {
                // Pull code from your GitHub repository
                git branch: 'main', url: 'https://github.com/dinesh-sirmal/Docker-file.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                // Build Docker image using Dockerfile in the project root
                sh "docker build -t $IMAGE_NAME ."
            }
        }

        stage('Run Docker Container') {
            steps {
                // Stop and remove any existing container
                sh "docker rm -f $CONTAINER_NAME || true"
                // Run new container
                sh "docker run -d --name $CONTAINER_NAME -p 8080:8080 $IMAGE_NAME"
            }
        }

        stage('Verify') {
            steps {
                // Show running containers
                sh "docker ps"
            }
        }
    }
}
